generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  TENANT_ADMIN
  MANAGER
  WAREHOUSE
  VIEWER
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  WASTE
  TRANSFER_IN
  TRANSFER_OUT
  INITIAL
  RETURN
}

enum MovementDirection {
  IN
  OUT
}

enum OutputReason {
  KITCHEN_USE
  WASTE
  EXPIRED
  ADJUSTMENT
  OTHER
}

enum AlertType {
  STOCK_LOW
  STOCK_OUT
  STOCK_OVERFLOW
  EXPIRATION_SOON
  HIGH_WASTE
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  DISMISSED
}

enum FeatureName {
  PURCHASE_ORDERS
  SUPPLIER_MANAGEMENT
  MULTI_WAREHOUSE
  WASTE_TRACKING
  ADVANCED_REPORTS
  API_ACCESS
  EMAIL_NOTIFICATIONS
  LOW_STOCK_ALERTS
  BARCODE_SCANNING
  RECIPE_MANAGEMENT
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  stockMovements   StockMovement[]
  inventoryEntries InventoryEntry[]
  inventoryOutputs InventoryOutput[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("categories")
}

model Unit {
  id        String    @id @default(uuid())
  name      String    @unique
  symbol    String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("units")
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products         Product[]
  inventoryEntries InventoryEntry[]

  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

// ─────────────────────────────────────────────
// PRODUCTS & INVENTORY
// ─────────────────────────────────────────────

model Product {
  id               String    @id @default(uuid())
  sku              String?   @unique
  name             String
  categoryId       String
  category         Category  @relation(fields: [categoryId], references: [id])
  unitId           String
  unit             Unit      @relation(fields: [unitId], references: [id])
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  minimumStock     Decimal   @default(0) @db.Decimal(10, 3)
  maximumStock     Decimal?  @db.Decimal(10, 3)
  tracksExpiration Boolean   @default(false)
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Relations
  stockLevel       StockLevel?
  stockMovements   StockMovement[]
  inventoryEntries InventoryEntry[]
  inventoryOutputs InventoryOutput[]
  alerts           Alert[]

  @@index([name])
  @@index([categoryId, isActive])
  @@index([isActive])
  @@map("products")
}

model StockLevel {
  id             String   @id @default(uuid())
  productId      String   @unique
  product        Product  @relation(fields: [productId], references: [id])
  currentStock   Decimal  @default(0) @db.Decimal(10, 3)
  lastMovementId String?
  updatedAt      DateTime @updatedAt

  @@map("stock_levels")
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  type          StockMovementType
  direction     MovementDirection
  quantity      Decimal           @db.Decimal(10, 3)
  stockBefore   Decimal           @db.Decimal(10, 3)
  stockAfter    Decimal           @db.Decimal(10, 3)
  unitCost      Decimal?          @db.Decimal(10, 2)
  referenceId   String?
  reason        String?
  notes         String?
  performedById String
  performedBy   User              @relation(fields: [performedById], references: [id])
  occurredAt    DateTime          @default(now())
  createdAt     DateTime          @default(now())

  @@index([productId, occurredAt])
  @@index([type, occurredAt])
  @@map("stock_movements")
}

model InventoryEntry {
  id            String    @id @default(uuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  quantity      Decimal   @db.Decimal(10, 3)
  unitCost      Decimal?  @db.Decimal(10, 2)
  entryDate     DateTime  @default(now())
  expirationDate DateTime?
  movementId    String?
  notes         String?
  performedById String
  performedBy   User      @relation(fields: [performedById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([entryDate])
  @@index([expirationDate])
  @@index([productId])
  @@map("inventory_entries")
}

model InventoryOutput {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  quantity      Decimal      @db.Decimal(10, 3)
  outputDate    DateTime     @default(now())
  outputReason  OutputReason
  movementId    String?
  notes         String?
  performedById String
  performedBy   User         @relation(fields: [performedById], references: [id])
  createdAt     DateTime     @default(now())

  @@index([outputDate])
  @@index([productId])
  @@map("inventory_outputs")
}

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────

model Alert {
  id          String      @id @default(uuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  alertType   AlertType
  status      AlertStatus @default(ACTIVE)
  detectedAt  DateTime    @default(now())
  resolvedAt  DateTime?

  @@index([alertType, status])
  @@index([productId, status])
  @@map("alerts")
}

// ─────────────────────────────────────────────
// SETTINGS & BRANDING
// ─────────────────────────────────────────────

model TenantSettings {
  id                   String   @id @default(uuid())
  restaurantName       String   @default("Mi Restaurante")
  systemName           String   @default("Stocken")
  timezone             String   @default("America/Costa_Rica")
  currency             String   @default("CRC")
  dateFormat           String   @default("DD/MM/YYYY")
  expirationAlertDays  Int      @default(7)
  allowNegativeStock   Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("tenant_settings")
}

model TenantBranding {
  id             String   @id @default(uuid())
  restaurantName String   @default("Mi Restaurante")
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#2563EB")
  secondaryColor String   @default("#64748B")
  accentColor    String   @default("#F59E0B")
  fontFamily     String   @default("Inter")
  emailFrom      String?
  supportEmail   String?
  locale         String   @default("es-CR")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  backgroundImageUrl String?

  @@map("tenant_branding")
}

// ─────────────────────────────────────────────
// FEATURE FLAGS
// ─────────────────────────────────────────────

model FeatureFlag {
  id        String      @id @default(uuid())
  feature   FeatureName @unique
  isEnabled Boolean     @default(false)
  updatedBy String?
  updatedAt DateTime    @updatedAt

  @@map("feature_flags")
}

// ─────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}